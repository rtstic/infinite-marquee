{
  "name": "@rtstic.dev/infinite-marquee",
  "version": "0.0.1",
  "description": "A smooth, glitch-free infinite marquee component using pure CSS animations and vanilla JavaScript.",
  "license": "MIT",
  "keywords": [
    "marquee",
    "infinite",
    "scroll",
    "animation",
    "css",
    "javascript",
    "web-component"
  ],
  "author": {
    "name": "Raimon",
    "url": "https://rtstic.dev"
  },
  "type": "module",
  "main": "dist/index.ts",
  "module": "dist/index.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development node ./bin/build.js",
    "build": "cross-env NODE_ENV=production node ./bin/build.js",
    "cdn": "node ./bin/cdn.js",
    "lint": "eslint ./src && prettier --check ./src",
    "lint:fix": "eslint ./src --fix",
    "check": "tsc --noEmit",
    "format": "prettier --write ./src",
    "release": "changeset publish",
    "update": "pnpm update -i -L -r"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "cross-env": "^7.0.3",
    "esbuild": "^0.25.5"
  }
}